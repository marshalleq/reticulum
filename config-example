[reticulum]
  enable_transport = True
  share_instance = Yes
  shared_instance_port = 37428
  instance_control_port = 37429

[logging]
  loglevel = 4

[interfaces]
  # Auckland mesh - RNode over WiFi
  [[Auckland Mesh]]
    type = RNodeInterface
    interface_enabled = True
    port = tcp://192.168.43.200
    frequency = 919000000
    bandwidth = 250000
    txpower = 17
    spreadingfactor = 9
    codingrate = 5

  # Uncomment to connect to the wider RNS network
  # [[Typenull Sydney]]
  #   type = TCPClientInterface
  #   interface_enabled = True
  #   target_host = rns.typenull.net
  #   target_port = 4242

  # Uncomment to allow inbound TCP connections
